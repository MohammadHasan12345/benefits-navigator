# Copy to .env for local Python dev, and set these in Vercel → Settings → Environment Variables.

# Google Gemini API key (the function accepts either name)
GEMINI_API_KEY=your-gemini-api-key
# GOOGLE_API_KEY=your-gemini-api-key

# Supabase (optional — the app falls back to bundled data if unset)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
